{
  "permissions": {
    "allow": [
      "Bash(npm --version)",
      "Bash(npm create *)",
      "Bash(mv irpf-web/* .)",
      "Bash(mv irpf-web/.* .)",
      "Bash(rm -rf irpf-web)",
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(curl -s http://localhost:5173)",
      "Bash(curl -s http://localhost:5173/@vite/client)",
      "Bash(pkill -f \"vite\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:5173)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:5175)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:5176)",
      "Bash(npx vite *)"
    ]
  }
}
